    "Migration": {
      "description": "Accounts, folders, or data not carried over from Classic Outlook to New Outlook",
      "match": ["from\\s*(classic|old)\\s*outlook", "not\\s*(carried|transferred|migrated|imported)", "didn'?t\\s*(carry|transfer|migrate|import)", "accounts?\\s*(missing|gone|disappeared|lost)", "manually\\s*(re-?add|add\\s*again|set\\s*up)", "switch(ed|ing)?\\s*to\\s*(the\\s*)?new\\s*outlook", "all\\s*my\\s*accounts?\\s*(are)?\\s*(gone|missing|disappeared)", "classic\\s*outlook", "old\\s*outlook", "forc(e|ed|ing)\\s*(to\\s*)?(switch|use|upgrade)", "bring\\s*back\\s*(classic|old)", "go\\s*back\\s*to\\s*(classic|old)", "new\\s*outlook\\s*(is|doesn'?t|won'?t|can'?t|lacks?|missing)"],
      "exclude": []
    },
    "Calendar Integration": {
      "description": "Calendar sync issues with third-party providers (iCloud, Google Calendar)",
      "match": ["calendar\\s*(not|won'?t|doesn'?t|isn'?t)?\\s*sync", "calendar\\s*(not|won'?t)?\\s*(show|display|appear|load|import)", "icloud\\s*calendar", "google\\s*calendar", "ical\\s*url", "caldav", "accept.*decline.*button", "meeting\\s*invit", "calendar\\s*events?\\s*(missing|gone|disappeared|lost)", "can'?t\\s*see\\s*(the\\s*)?meeting", "meeting\\w*\\s*(not|don'?t|doesn'?t|won'?t|missing|gone)", "remove\\s*(a\\s*)?\\w*\\s*calendar"],
      "exclude": []
    },
    "Rules Missing": {
      "description": "Inbox rules/filters not available for IMAP or Gmail accounts",
      "match": ["rules?\\s*(not|don'?t|doesn'?t|won'?t|can'?t)", "no\\s*rules?", "rules?\\s*(missing|unavailable|disabled|greyed|grayed)", "rules?.*not\\s*(available|support|work)", "rules?.*unavailable", "need\\s*rules", "want\\s*rules", "rules?.*for\\s*(my\\s*)?(gmail|imap|yahoo|aol|icloud)", "filter\\s*(not|don'?t|doesn'?t)", "auto-?(forward|move|sort)\\s*(not|doesn'?t|can'?t)", "can'?t\\s*(create|set|make|use)\\s*rules?"],
      "exclude": []
    },
    "Display Name": {
      "description": "Cannot change sender display name on IMAP/third-party accounts",
      "match": ["display\\s*name", "sender\\s*name", "from\\s*name", "shown?\\s*name", "change\\s*(my)?\\s*name"],
      "exclude": ["user\\s*name", "account\\s*name"]
    },
    "Search": {
      "description": "Search not working or limited — can't find emails, search broken, results missing",
      "match": ["search\\s*(not|doesn'?t|won'?t|can'?t|isn'?t)", "can'?t\\s*search", "cannot\\s*search", "doesn'?t\\s*search", "does\\s*not\\s*search", "search\\s*(broken|fail|error|issue|problem|missing|limited|slow)", "search.*not\\s*work", "no\\s*search", "search\\s*bar", "find\\s*(my\\s*)?(email|mail|message)", "search\\s*function", "search\\s*result", "search\\s*work", "search.*gmail"],
      "exclude": ["bing", "web\\s*search"]
