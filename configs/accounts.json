  "feature_tags": [
    "IMAP", "CloudCache", "IMAPCloudCache", "Calendar", "Settings",
    "Password", "Service", "Notifications", "To-Do", "HowTo",
    "Perf", "Organize and act", "AuthCancel", "MonarchAuthCancel"
