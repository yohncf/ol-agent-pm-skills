{
  "name": "Accounts",
  "description": "Outlook Monarch Accounts area — Cloud Cache, IMAP, Gmail, third-party account issues",
  "ocv_url": "https://ocv.microsoft.com/#/discover/?spt=Filters&aid=ab531f38-ec99-4256-91e9-d8a7240f154e&searchtype=OcvItems&relDateType=day&offset=0&vs=%7B%22view%22:%22list%22,%22co%22:%5B%7B%22n%22:%22DetailsPageLink%22,%22w%22:30%7D,%7B%22n%22:%22FeedbackType%22%7D,%7B%22n%22:%22Comment%22,%22w%22:350%7D,%7B%22n%22:%22CreatedDate%22%7D,%7B%22n%22:%22Area%22%7D,%7B%22n%22:%22Theme%22%7D,%7B%22n%22:%22Issue%22%7D,%7B%22n%22:%22Tags%22%7D,%7B%22n%22:%22Platform%22%7D%5D%7D&q=(Product:%22Outlook%20Monarch%22)%20AND%20(OcvAreas.Path:%22Outlook%20Monarch%5C%5CAccounts%22)",

  "entity": {
    "type": "provider",
    "source": "email_domain",
    "whitelist_file": "isp_whitelist.json",
    "redacted_label": "[CUSTOM_DOMAIN]"
  },

  "categories": {
    "Sign-in": {
      "description": "Authentication failures — can't log in, credentials rejected, login errors",
      "match": ["log\\s*in", "log\\s*into", "log-in", "sign\\s*in", "sign-in", "signin", "authenticat\\w*", "need\\s*password", "password\\s*(fail|error|wrong|incorrect|invalid|expired|reset|issue|problem)", "can'?t\\s*(log|sign)", "unable\\s*to\\s*(log|sign)", "login\\s*(fail|error|issue|problem)"],
      "require": ["fail", "error", "did\\s*not\\s*work", "not\\s*able", "unable", "cannot", "can'?t", "couldn'?t", "could\\s*not", "will\\s*not", "wouldn'?t", "won'?t", "cant", "not\\s*working"],
      "exclude": ["restart", "reboot", "shared", "team\\s*meeting", "group", "zoom"]
    },
    "Send/Receive": {
      "description": "Mail sync failures — not receiving, can't send, inbox stale, emails missing",
      "match": ["sync", "syncing", "synchroniz\\w*", "not\\s*receiving", "not\\s*getting", "stopped\\s*receiving", "stopped\\s*coming", "can'?t\\s*receive", "can'?t\\s*send", "cannot\\s*receive", "cannot\\s*send", "won'?t\\s*send", "doesn'?t\\s*send", "does\\s*not\\s*send", "not\\s*coming", "no\\s*email", "no\\s*mail", "no\\s*emails", "new\\s*messages?", "new\\s*mail", "new\\s*emails?", "get\\s*mail", "get\\s*email", "missing\\s*(email|mail|message)", "not\\s*seeing", "don'?t\\s*see\\s*(all\\s*)?(the\\s*)?(email|mail|message)", "come\\s*through", "access\\s*email", "show\\s*emails?", "receiv\\w*", "send\\s*or\\s*receive", "send\\s*and\\s*receive", "load\\s*(email|mail|message)", "retriev\\w*", "stopped\\s*getting", "not\\s*deliver", "undelivered", "up\\s*to\\s*date"],
      "exclude": ["notification", "alert", "spam", "junk", "ads?", "advert", "invitation", "invite", "reminder", "attachment"]
    },
    "Account Setup": {
      "description": "Cannot add or configure a third-party account — setup errors, connection failures",
      "match": ["can'?t\\s*add", "cannot\\s*add", "unable\\s*to\\s*add", "won'?t\\s*add", "add\\s*(my|an|the)?\\s*account", "add\\s*(my|an)?\\s*(email|mail)", "setup\\s*(fail|error)", "set\\s*up\\s*(fail|error)", "configure\\s*(fail|error)", "connect\\s*(my|an)?\\s*account", "account\\s*creation", "something\\s*went\\s*wrong", "access\\s*denied", "not\\s*supported"],
      "exclude": ["shared\\s*mailbox", "delegate"]
    },
    "Auth Loop": {
      "description": "Repeated authentication prompts — password asked every session, credentials not saved",
      "match": ["keeps?\\s*asking", "password\\s*again", "re-authenticat", "reauthenticat", "login\\s*loop", "every\\s*time\\s*I\\s*open", "every\\s*time\\s*I\\s*start", "every\\s*time\\s*I\\s*launch", "constantly\\s*(ask|prompt|requir)", "repeatedly\\s*(ask|prompt|requir)", "always\\s*(ask|prompt|requir)", "keeps?\\s*logging\\s*(me)?\\s*out", "keeps?\\s*signing\\s*(me)?\\s*out", "credentials\\s*(lost|forgotten|missing)", "password\\s*not\\s*saved"],
      "exclude": []
