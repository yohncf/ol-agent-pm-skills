      "exclude": ["spam\\s*folder", "junk\\s*folder"]
    },
    "Contacts": {
      "description": "Contacts not syncing, missing, or not visible from third-party accounts",
      "match": ["contact\\w*\\s*(not|don'?t|doesn'?t|won'?t|can'?t|missing|gone|disappeared|lost|empty|sync)", "contact\\w*.*disappear", "contact\\w*.*not\\s*(available|visible|show|display)", "no\\s*contact", "my\\s*contact", "address\\s*book", "contact\\s*list", "people\\s*(not|missing|gone)", "can'?t\\s*see.*contact", "can'?t\\s*(find|access)\\s*contact", "lost.*contact", "amalgamate.*contact", "\\w+\\s*account\\s*contact"],
      "exclude": ["support\\s*contact", "contact\\s*(us|microsoft|support|help)"]
    },
    "Threading": {
      "description": "Conversation view and threading issues — messages not grouped, thread display problems",
      "match": ["thread\\w*", "conversation\\s*view", "conversation\\s*mode", "group(ed|ing)?\\s*(by\\s*)?conversation", "messages?\\s*group", "email\\s*chain", "reply\\s*chain", "collapsed\\s*thread"],
      "exclude": []
    },
    "Multiple Accounts": {
      "description": "Issues managing multiple email accounts — switching, unified view, account conflicts",
      "match": ["multiple\\s*account", "several\\s*account", "two\\s*account", "three\\s*account", "all\\s*(my)?\\s*account", "switch(ing)?\\s*(between)?\\s*account", "unified\\s*(inbox|view|mailbox)", "combined\\s*(inbox|view|mailbox)", "combine\\s*(email|mail|account|inbox)", "merge\\s*(email|mail|account|inbox)", "different\\s*account"],
      "exclude": []
    },
    "Connection": {
      "description": "Connection or network errors when accessing third-party email servers",
      "match": ["connection\\s*(fail|error|issue|problem|lost|timeout|refused)", "can'?t\\s*connect", "cannot\\s*connect", "unable\\s*to\\s*connect", "no\\s*connection", "server\\s*(error|down|unavailable|unreachable)", "timed?\\s*out", "network\\s*(error|issue|problem)", "disconnect\\w*"],
      "exclude": ["vpn", "wifi", "internet\\s*connection"]
    },
    "Gmail Comparison": {
      "description": "Feature gap feedback comparing Outlook to Gmail — user wants Gmail-like functionality",
      "match": ["gmail\\s*(has|had|does|did|can|could|allows?|lets?|offers?)", "(like|as)\\s*(in\\s*)?gmail", "gmail\\s*(version|app|web|interface)", "in\\s*gmail\\s*(you|we|I|it)", "gmail\\s*feature", "gmail\\s*style", "works?\\s*in\\s*gmail", "available\\s*in\\s*gmail", "worse\\s*than\\s*gmail", "better\\s*than.*gmail", "compared\\s*to\\s*gmail"],
      "exclude": []
