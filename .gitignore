# Dependencies
node_modules/

# Extracted data and analysis outputs (customer content — do not commit)
data/*
!data/.gitkeep
!data/manifests/
data/manifests/*
!data/manifests/.gitkeep

# Browser profiles (SSO cookies)
.browser-profile/
.browser-profile-ods/
.browser-profile-dash/

# Personal configs (contain area-specific OCV URLs)
configs/*.json
!configs/_template.json
!configs/accounts.json

# FHL demo and presentation materials (personal content)
demo/
docs/FHL_*.md

# Local AI assistant settings
.claude/settings.local.json

# OS files
Thumbs.db
.DS_Store

# Python bytecode
__pycache__/
*.pyc

# Local sandboxes / nested clones (must never be committed to this repo)
_ocv_weekly_repo/
_ocv_weekly_personal/

# Local diagnostic logs and one-off scratch files
gcm-diagnose.log
.ocv_input.txt

# Eval-side runtime artifacts (parallel to data/)
eval-manifests/
eval-reports/
